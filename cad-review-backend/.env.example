# LLM provider (default example: OpenRouter)
KIMI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_MODEL=openrouter/healer-alpha
OPENROUTER_REASONING_ENABLED=1
OPENROUTER_HTTP_REFERER=http://localhost:7001
OPENROUTER_X_TITLE=ccad-local

# Optional Kimi official / code fallback
KIMI_OFFICIAL_API_KEY=sk-your-official-key
KIMI_CODE_API_KEY=sk-kimi-your-code-key
FEEDBACK_AGENT_MODE=llm
FEEDBACK_AGENT_PROVIDER=api
FEEDBACK_AGENT_MAX_TOKENS=1200
AUDIT_RUNNER_PROVIDER=api
AUDIT_PROJECT_OPENROUTER_MAX_CONCURRENCY=2
AUDIT_PROJECT_KIMI_SDK_MAX_CONCURRENCY=1
AUDIT_PROJECT_OPENROUTER_MIN_INTERVAL_SECONDS=0
AUDIT_PROJECT_KIMI_SDK_MIN_INTERVAL_SECONDS=0
CCAD_RUNNER_RAW_OUTPUT_DIR=/tmp/ccad_runner_raw_outputs

# Optional: backend runtime hints
CCAD_BACKEND_PORT=7002
CCAD_FRONTEND_DEV_PORT=7001
CCAD_CORS_ORIGINS=http://localhost:7001,http://127.0.0.1:7001

# Optional: storage / db location overrides
CCAD_PROJECTS_ROOT=
CCAD_LEGACY_WORKSPACE_PROJECTS_ROOT=
CCAD_DB_BASE_DIR=
