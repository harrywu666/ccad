# Kimi provider (default: official)
KIMI_PROVIDER=official
KIMI_OFFICIAL_API_KEY=sk-your-official-key
KIMI_CODE_API_KEY=sk-kimi-your-code-key
FEEDBACK_AGENT_MODE=llm
FEEDBACK_AGENT_PROVIDER=sdk
FEEDBACK_AGENT_MAX_TOKENS=1200
AUDIT_RUNNER_PROVIDER=sdk

# Optional: backend runtime hints
CCAD_BACKEND_PORT=7002
CCAD_FRONTEND_DEV_PORT=7001
CCAD_CORS_ORIGINS=http://localhost:7001,http://127.0.0.1:7001

# Optional: storage / db location overrides
CCAD_PROJECTS_ROOT=
CCAD_LEGACY_WORKSPACE_PROJECTS_ROOT=
CCAD_DB_BASE_DIR=
